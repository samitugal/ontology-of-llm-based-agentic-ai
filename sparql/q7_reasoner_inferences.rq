PREFIX : <http://www.ege.edu.tr/cs/ontology/llm-agent#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

SELECT ?agent ?inferredType WHERE {
  ?agent rdf:type :Agent ;
         rdf:type ?inferredType .
  FILTER(?inferredType IN (:AutonomousAgent, :MemoryAugmentedAgent, :PlanningAgent))
}
ORDER BY ?agent ?inferredType
