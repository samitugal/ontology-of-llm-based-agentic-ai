        <llm-agent:modelProvider rdf:datatype="xsd:string">Meta</llm-agent:modelProvider>
        <llm-agent:modelVersion rdf:datatype="xsd:string">3.1</llm-agent:modelVersion>
        <llm-agent:contextLength rdf:datatype="xsd:integer">128000</llm-agent:contextLength>
