        <llm-agent:hasPrompt rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ExecutorSystemPrompt"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#ReviewerConfig">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ModelConfiguration"/>
        <llm-agent:usesModel rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Llama3"/>
        <llm-agent:hasPrompt rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ReviewerSystemPrompt"/>
    </owl:NamedIndividual>

    <!-- KAYNAKLAR -->

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#WebResource">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Resource"/>
        <llm-agent:resourceType rdf:datatype="xsd:string">web</llm-agent:resourceType>
        <llm-agent:accessMode rdf:datatype="xsd:string">read</llm-agent:accessMode>
        <llm-agent:resourceURI rdf:datatype="xsd:anyURI">https://www.example.com</llm-agent:resourceURI>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#CodeResource">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Resource"/>
        <llm-agent:resourceType rdf:datatype="xsd:string">code_sandbox</llm-agent:resourceType>
        <llm-agent:accessMode rdf:datatype="xsd:string">read_write</llm-agent:accessMode>
        <llm-agent:resourceURI rdf:datatype="xsd:anyURI">sandbox://code</llm-agent:resourceURI>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#FileResource">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Resource"/>
        <llm-agent:resourceType rdf:datatype="xsd:string">filesystem</llm-agent:resourceType>
        <llm-agent:accessMode rdf:datatype="xsd:string">read</llm-agent:accessMode>
        <llm-agent:resourceURI rdf:datatype="xsd:anyURI">file:///data</llm-agent:resourceURI>
