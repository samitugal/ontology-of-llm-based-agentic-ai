        <llm-agent:modelProvider rdf:datatype="xsd:string">OpenAI</llm-agent:modelProvider>
        <llm-agent:modelVersion rdf:datatype="xsd:string">2024-11</llm-agent:modelVersion>
        <llm-agent:contextLength rdf:datatype="xsd:integer">128000</llm-agent:contextLength>
        <llm-agent:supportsFunctionCalling rdf:datatype="xsd:boolean">true</llm-agent:supportsFunctionCalling>
    </owl:NamedIndividual>

