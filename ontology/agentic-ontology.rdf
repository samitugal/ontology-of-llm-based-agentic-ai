        <llm-agent:paramType rdf:datatype="xsd:string">integer</llm-agent:paramType>
    </owl:NamedIndividual>

    <!-- PROMPTLAR -->

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#OrchestratorSystemPrompt">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#SystemPrompt"/>
        <llm-agent:promptText rdf:datatype="xsd:string">You are an orchestrator agent. Coordinate the research team and delegate tasks appropriately.</llm-agent:promptText>
        <llm-agent:forRole rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#System"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#PlannerSystemPrompt">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#SystemPrompt"/>
        <llm-agent:promptText rdf:datatype="xsd:string">You are a research planning agent. Analyze tasks and create structured research plans without executing them directly.</llm-agent:promptText>
        <llm-agent:forRole rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#System"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#ExecutorSystemPrompt">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#SystemPrompt"/>
        <llm-agent:promptText rdf:datatype="xsd:string">You are a code execution agent. Execute tasks using available tools and report results.</llm-agent:promptText>
        <llm-agent:forRole rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#System"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#ReviewerSystemPrompt">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#SystemPrompt"/>
        <llm-agent:promptText rdf:datatype="xsd:string">You are a reviewer agent. Evaluate outputs and provide structured feedback.</llm-agent:promptText>
        <llm-agent:forRole rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#System"/>
    </owl:NamedIndividual>

    <!-- MODEL KONFIGURASYONLARI -->

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#OrchestratorConfig">
