<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.ege.edu.tr/cs/ontology/llm-agent#"
     xml:base="http://www.ege.edu.tr/cs/ontology/llm-agent"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:oasis="http://www.dmi.unict.it/oasis2#"
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:llm-agent="http://www.ege.edu.tr/cs/ontology/llm-agent#">
    <owl:Ontology rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent">
        <owl:versionIRI rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent/0.1"/>
        <owl:imports rdf:resource="http://www.dmi.unict.it/oasis2"/>
        <owl:versionInfo>1.0.0</owl:versionInfo>
        <dcterms:title xml:lang="tr">BDM Tabanli Etmen Sistemleri Ontolojisi</dcterms:title>
        <dcterms:creator>Sami Tugal (ORCID: 0009-0008-6595-7053)</dcterms:creator>
        <dcterms:creator>Murat Osman Unalir (ORCID: 0000-0003-4531-0566)</dcterms:creator>
        <dcterms:identifier>https://doi.org/10.5281/zenodo.20571345</dcterms:identifier>
        <rdfs:seeAlso rdf:resource="https://github.com/samitugal/ontology-of-llm-based-agentic-ai"/>
        <rdfs:comment>BDM Tabanli Etmen Sistemleri Ontolojisi. OASIS 2 ile entegre, cerceve bagimsiz LLM-agent ontolojisi.</rdfs:comment>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- xsd:string -->

    <rdfs:Datatype rdf:about="xsd:string"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#accessesResource -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#accessesResource">
        <rdfs:label xml:lang="en">accesses resource</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Tool'un erisim sagladigi Resource'u belirten iliski.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Tool"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Resource"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#capabilityOf -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#capabilityOf">
        <rdfs:label xml:lang="en">capability of</rdfs:label>
        <rdfs:comment xml:lang="tr">hasCapability'nin tersi: bir Capability'nin sahibi olan Agent'i isaret eden iliski.</rdfs:comment>
        <owl:inverseOf rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#hasCapability"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Capability"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#coordinatesVia -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#coordinatesVia">
        <rdfs:label xml:lang="en">coordinates via</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir AgentGroup'un uzerinden koordine oldugu Workflow'u belirten iliski.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#AgentGroup"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Workflow"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#delegatedBy -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#delegatedBy">
        <rdfs:label xml:lang="en">delegated by</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Delegation kaydinin hangi Agent tarafindan baslatildigini belirten iliski.</rdfs:comment>
        <owl:inverseOf rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#delegatesTo"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Delegation"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#delegatedTask -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#delegatedTask">
        <rdfs:label xml:lang="en">delegated task</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Delegation icinde devredilen Task'i isaret eden iliski (functional).</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Delegation"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Task"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#delegatesTo -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#delegatesTo">
        <rdfs:label xml:lang="en">delegates to</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Agent'in gorev devrettigi diger Agent'i isaret eden iliski (asymmetric + irreflexive).</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Delegation"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#delegator -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#delegator">
        <rdfs:label xml:lang="en">delegator</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Delegation icindeki devreden Agent'i isaret eden iliski (functional).</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Delegation"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#followsProtocol -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#followsProtocol">
        <rdfs:label xml:lang="en">follows protocol</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Channel'in uyguladigi Protocol'u belirten iliski.</rdfs:comment>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Channel"/>
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Delegation"/>
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Workflow"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Protocol"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#forRole -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#forRole">
        <rdfs:label xml:lang="en">for role</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir AgentTemplate'in hangi Role icin tasarlandigini belirten iliski.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Prompt"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#MessageRole"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#generatedBy -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#generatedBy">
        <rdfs:label xml:lang="en">generated by</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Message'in uretildigi Session'i isaret eden iliski (functional).</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#AgentMessage"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#hasAction -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#hasAction">
        <rdfs:label xml:lang="en">has action</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Workflow veya Plan'in icerdigi Action'i baglayan iliski.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ToolCall"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Action"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#hasCapability -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#hasCapability">
        <rdfs:label xml:lang="en">has capability</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Agent'in sahip oldugu Capability'i baglayan iliski (someValuesFrom kisitiyla zorunlu).</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Capability"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#hasConfiguration -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#hasConfiguration">
        <rdfs:label xml:lang="en">has configuration</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Agent'in calistigi ModelConfiguration'i belirten iliski (functional + tam-1 kardinalite).</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ModelConfiguration"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#hasContext -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#hasContext">
        <rdfs:label xml:lang="en">has context</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Agent veya Session'in aktif Context'ini baglayan iliski.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Context"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#hasMember -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#hasMember">
        <rdfs:label xml:lang="en">has member</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir AgentGroup'un icerdigi Agent'lari baglayan iliski.</rdfs:comment>
        <owl:inverseOf rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#memberOf"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#AgentGroup"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#hasMemory -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#hasMemory">
        <rdfs:label xml:lang="en">has memory</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Agent'in sahip oldugu Memory'yi baglayan iliski; AutonomousAgent ve MemoryAugmentedAgent tanimlari icin kullanilir.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Memory"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#hasMemoryStrategy -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#hasMemoryStrategy">
        <rdfs:label xml:lang="en">has memory strategy</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Memory'nin uyguladigi MemoryStrategy'i belirten iliski.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Memory"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#MemoryStrategy"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#hasMessage -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#hasMessage">
        <rdfs:label xml:lang="en">has message</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Session'in icerdigi Message'lari baglayan iliski.</rdfs:comment>
        <owl:inverseOf rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#partOfSession"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Session"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Message"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#hasMessageRole -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#hasMessageRole">
        <rdfs:label xml:lang="en">has message role</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Message'in MessageRole'unu belirten iliski (functional).</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Message"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#MessageRole"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#hasObservation -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#hasObservation">
        <rdfs:label xml:lang="en">has observation</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Session'in urettigi Observation kayitlarini baglayan iliski.</rdfs:comment>
        <owl:inverseOf rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#observedIn"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Session"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Observation"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#hasParameter -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#hasParameter">
        <rdfs:label xml:lang="en">has parameter</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir ModelConfiguration'in icerdigi Parameter'leri baglayan iliski.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ModelConfiguration"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Parameter"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#hasPlan -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#hasPlan">
        <rdfs:label xml:lang="en">has plan</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Task veya Workflow'un izledigi Plan'i belirten iliski.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Workflow"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Plan"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#hasPolicy -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#hasPolicy">
        <rdfs:label xml:lang="en">has policy</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Agent'in uyguladigi Policy'leri baglayan iliski.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Policy"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#hasPrompt -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#hasPrompt">
        <rdfs:label xml:lang="en">has prompt</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Agent veya AgentTemplate'in kullandigi Prompt'u baglayan iliski.</rdfs:comment>
        <owl:inverseOf rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#promptOf"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ModelConfiguration"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Prompt"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#hasRole -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#hasRole">
        <rdfs:label xml:lang="en">has role</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Agent'in ustlendigi Role'u baglayan iliski.</rdfs:comment>
        <owl:inverseOf rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#playedBy"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Role"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#hasSession -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#hasSession">
        <rdfs:label xml:lang="en">has session</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Agent'in dahil oldugu Session'lari baglayan iliski.</rdfs:comment>
        <owl:inverseOf rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#sessionOf"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#AgentGroup"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Session"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#hasSharedMemory -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#hasSharedMemory">
        <rdfs:label xml:lang="en">has shared memory</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir AgentGroup'un paylasilan Memory'sini belirten iliski.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#AgentGroup"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Memory"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#hasStep -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#hasStep">
        <rdfs:label xml:lang="en">has step</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Plan'in icerdigi Task adimlarini baglayan iliski (allValuesFrom Task).</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Plan"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Task"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#instantiates -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#instantiates">
        <rdfs:label xml:lang="en">instantiates</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Agent'in hangi AgentTemplate'ten somutlastirildigini belirten iliski.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#AgentTemplate"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ModelConfiguration"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#invokedBy -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#invokedBy">
        <rdfs:label xml:lang="en">invoked by</rdfs:label>
        <rdfs:comment xml:lang="tr">invokesTool'un tersi: bir Tool'un hangi ToolCall tarafindan cagrildigini belirten iliski.</rdfs:comment>
        <owl:inverseOf rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#invokesTool"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Tool"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ToolCall"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#invokesTool -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#invokesTool">
        <rdfs:label xml:lang="en">invokes tool</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir ToolCall'in cagirdigi Tool'u belirten iliski.</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ToolCall"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Tool"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#madeBy -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#madeBy">
        <rdfs:label xml:lang="en">made by</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir ToolCall'in hangi Agent tarafindan yapildigini belirten iliski.</rdfs:comment>
        <owl:inverseOf rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#makesToolCall"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ToolCall"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#makesToolCall -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#makesToolCall">
        <rdfs:label xml:lang="en">makes tool call</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Agent'in urettigi ToolCall'lari baglayan iliski; AutonomousAgent tanimi icin kullanilir.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ToolCall"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#memberOf -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#memberOf">
        <rdfs:label xml:lang="en">member of</rdfs:label>
        <rdfs:comment xml:lang="tr">hasMember'in tersi: bir Agent'in dahil oldugu AgentGroup'u belirten iliski.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#AgentGroup"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#observedIn -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#observedIn">
        <rdfs:label xml:lang="en">observed in</rdfs:label>
        <rdfs:comment xml:lang="tr">hasObservation'in tersi: bir Observation'in ait oldugu Session'i belirten iliski.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Observation"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Session"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#partOfSession -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#partOfSession">
        <rdfs:label xml:lang="en">part of session</rdfs:label>
        <rdfs:comment xml:lang="tr">hasMessage'in tersi: bir Message'in ait oldugu Session'i belirten iliski.</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Message"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Session"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#playedBy -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#playedBy">
        <rdfs:label xml:lang="en">played by</rdfs:label>
        <rdfs:comment xml:lang="tr">hasRole'un tersi: bir Role'un hangi Agent tarafindan ustlenildigini belirten iliski.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Role"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#producesResult -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#producesResult">
        <rdfs:label xml:lang="en">produces result</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir ToolCall'in urettigi ToolResult'u belirten iliski.</rdfs:comment>
        <owl:inverseOf rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#resultOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ToolCall"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ToolResult"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#promptOf -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#promptOf">
        <rdfs:label xml:lang="en">prompt of</rdfs:label>
        <rdfs:comment xml:lang="tr">hasPrompt'un tersi: bir Prompt'un hangi Agent veya AgentTemplate'e ait oldugunu belirten iliski.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Prompt"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ModelConfiguration"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#recordsSession -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#recordsSession">
        <rdfs:label xml:lang="en">records session</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Memory'nin kayit altinda tuttugu Session'i belirten iliski; hafiza katmaninda Session'i MemoryContent olarak baglar.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#EpisodicMemory"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Session"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#resultOf -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#resultOf">
        <rdfs:label xml:lang="en">result of</rdfs:label>
        <rdfs:comment xml:lang="tr">producesResult'un tersi: bir ToolResult'un hangi ToolCall'a ait oldugunu belirten iliski.</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ToolResult"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ToolCall"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#runsIn -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#runsIn">
        <rdfs:label xml:lang="en">runs in</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Task veya Workflow'un calistirildigi ExecutionContext'i belirten iliski.</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Task"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ExecutionContext"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#sessionOf -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#sessionOf">
        <rdfs:label xml:lang="en">session of</rdfs:label>
        <rdfs:comment xml:lang="tr">hasSession'in tersi: bir Session'in hangi Agent'a ait oldugunu belirten iliski.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Session"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#AgentGroup"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#storesMessage -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#storesMessage">
        <rdfs:label xml:lang="en">stores message</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Memory'nin sakladigi Message'lari belirten iliski; hafiza katmaninda Message'i MemoryContent olarak baglar.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ShortTermMemory"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Message"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#subtaskOf -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#subtaskOf">
        <rdfs:label xml:lang="en">subtask of</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Subtask'in hangi Task'a ait oldugunu belirten iliski (transitif olabilen alt-gorev iliskisi).</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Subtask"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Task"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#toolFor -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#toolFor">
        <rdfs:label xml:lang="en">tool for</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Tool'un hangi Capability'i destekledigini belirten iliski.</rdfs:comment>
        <owl:inverseOf rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#usesTool"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Tool"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Capability"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#triggeredBy -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#triggeredBy">
        <rdfs:label xml:lang="en">triggered by</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Action veya Workflow'un hangi Event/Agent tarafindan tetiklendigini belirten iliski.</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Delegation"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Policy"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#usesModel -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#usesModel">
        <rdfs:label xml:lang="en">uses model</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir ModelConfiguration'in basvurdugu LLMModel'i belirten iliski.</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ModelConfiguration"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#LLMModel"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#usesTool -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#usesTool">
        <rdfs:label xml:lang="en">uses tool</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Agent veya Capability'nin kullandigi Tool'u belirten iliski.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Capability"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Tool"/>
    </owl:ObjectProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#viaChannel -->

    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#viaChannel">
        <rdfs:label xml:lang="en">via channel</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Delegation veya Message'in iletildigi Channel'i belirten iliski.</rdfs:comment>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Delegation"/>
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Workflow"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Channel"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#accessMode -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#accessMode">
        <rdfs:label xml:lang="en">access mode</rdfs:label>
        <rdfs:comment xml:lang="tr">Resource'un erisim modu (read, write, read-write).</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#actionName -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#actionName">
        <rdfs:label xml:lang="en">action name</rdfs:label>
        <rdfs:comment xml:lang="tr">Action ornegi icin insan-okur ad.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Action"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#agentId -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#agentId">
        <rdfs:label xml:lang="en">agent id</rdfs:label>
        <rdfs:comment xml:lang="tr">Agent ornegi icin essiz tanimlayici.</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#agentName -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#agentName">
        <rdfs:label xml:lang="en">agent name</rdfs:label>
        <rdfs:comment xml:lang="tr">Agent ornegi icin insan-okur ad.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#agentVersion -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#agentVersion">
        <rdfs:label xml:lang="en">agent version</rdfs:label>
        <rdfs:comment xml:lang="tr">Agent yapilandirmasinin surum etiketi.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#callId -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#callId">
        <rdfs:label xml:lang="en">call id</rdfs:label>
        <rdfs:comment xml:lang="tr">ToolCall ornegi icin essiz tanimlayici.</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ToolCall"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#callTimestamp -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#callTimestamp">
        <rdfs:label xml:lang="en">call timestamp</rdfs:label>
        <rdfs:comment xml:lang="tr">ToolCall'in baslatildigi zaman damgasi (xsd:dateTime).</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ToolCall"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#capabilityName -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#capabilityName">
        <rdfs:label xml:lang="en">capability name</rdfs:label>
        <rdfs:comment xml:lang="tr">Capability ornegi icin insan-okur ad.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Capability"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#channelEndpoint -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#channelEndpoint">
        <rdfs:label xml:lang="en">channel endpoint</rdfs:label>
        <rdfs:comment xml:lang="tr">Channel'in baglandigi uc nokta (URI veya adres).</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Channel"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#channelType -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#channelType">
        <rdfs:label xml:lang="en">channel type</rdfs:label>
        <rdfs:comment xml:lang="tr">Channel turu (http, websocket, in-process vb.).</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Channel"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#contextId -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#contextId">
        <rdfs:label xml:lang="en">context id</rdfs:label>
        <rdfs:comment xml:lang="tr">Context ornegi icin essiz tanimlayici.</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ExecutionContext"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#contextLength -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#contextLength">
        <rdfs:label xml:lang="en">context length</rdfs:label>
        <rdfs:comment xml:lang="tr">Aktif baglamdaki token sayisi.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#LLMModel"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#contextSnapshot -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#contextSnapshot">
        <rdfs:label xml:lang="en">context snapshot</rdfs:label>
        <rdfs:comment xml:lang="tr">Belirli bir andaki Context'in serilestirilmis temsili.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Context"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#contextWindowSize -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#contextWindowSize">
        <rdfs:label xml:lang="en">context window size</rdfs:label>
        <rdfs:comment xml:lang="tr">LLMModel'in destekledigi maksimum baglam pencere boyutu (token cinsinden).</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Context"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#cost -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#cost">
        <rdfs:label xml:lang="en">cost</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir cagri veya gorevin tahmini para birimi cinsinden maliyeti.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Observation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#createdAt -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#createdAt">
        <rdfs:label xml:lang="en">created at</rdfs:label>
        <rdfs:comment xml:lang="tr">Olusturma zaman damgasi (xsd:dateTime).</rdfs:comment>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Delegation"/>
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Message"/>
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Session"/>
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Task"/>
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#ToolCall"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#delegatedAt -->

