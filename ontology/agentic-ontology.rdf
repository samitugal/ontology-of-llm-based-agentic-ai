    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#DBResource">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Resource"/>
        <llm-agent:resourceType rdf:datatype="xsd:string">database</llm-agent:resourceType>
        <llm-agent:accessMode rdf:datatype="xsd:string">read</llm-agent:accessMode>
        <llm-agent:resourceURI rdf:datatype="xsd:anyURI">postgresql://db.example.com/research</llm-agent:resourceURI>
    </owl:NamedIndividual>

    <!-- ARACLAR -->

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#WebSearchTool">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Tool"/>
        <llm-agent:toolName rdf:datatype="xsd:string">web_search</llm-agent:toolName>
        <llm-agent:toolVersion rdf:datatype="xsd:string">1.0</llm-agent:toolVersion>
