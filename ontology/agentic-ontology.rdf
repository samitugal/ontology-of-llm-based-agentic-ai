    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#resourceURI">
        <rdfs:label xml:lang="en">resource URI</rdfs:label>
        <rdfs:comment xml:lang="tr">Resource'a karsilik gelen kaynak URI'si.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Resource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#resultPayload -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#resultPayload">
        <rdfs:label xml:lang="en">result payload</rdfs:label>
        <rdfs:comment xml:lang="tr">ToolResult'in icerdigi serbest icerik (JSON veya metin).</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ToolResult"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#resultStatus -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#resultStatus">
        <rdfs:label xml:lang="en">result status</rdfs:label>
        <rdfs:comment xml:lang="tr">ToolResult durumu (success, failure, partial).</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ToolResult"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#roleName -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#roleName">
        <rdfs:label xml:lang="en">role name</rdfs:label>
        <rdfs:comment xml:lang="tr">Role ornegi icin insan-okur ad.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Role"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#sessionId -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#sessionId">
        <rdfs:label xml:lang="en">session id</rdfs:label>
        <rdfs:comment xml:lang="tr">Session ornegi icin essiz tanimlayici.</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Session"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#sessionStatus -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#sessionStatus">
        <rdfs:label xml:lang="en">session status</rdfs:label>
        <rdfs:comment xml:lang="tr">Session durumu (active, paused, ended).</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Session"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#startTime -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#startTime">
        <rdfs:label xml:lang="en">start time</rdfs:label>
        <rdfs:comment xml:lang="tr">Session veya Task icin baslangic zaman damgasi (xsd:dateTime).</rdfs:comment>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Session"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#stepOrder -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#stepOrder">
        <rdfs:label xml:lang="en">step order</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Plan icindeki Task adiminin sira numarasi (integer).</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Subtask"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#strategyAlgorithm -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#strategyAlgorithm">
        <rdfs:label xml:lang="en">strategy algorithm</rdfs:label>
        <rdfs:comment xml:lang="tr">MemoryStrategy icin kullanilan algoritmanin adi (orn. LRU, FIFO, top-k).</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#MemoryStrategy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#strategyName -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#strategyName">
        <rdfs:label xml:lang="en">strategy name</rdfs:label>
        <rdfs:comment xml:lang="tr">MemoryStrategy ornegi icin insan-okur ad.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#MemoryStrategy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#supportsFunctionCalling -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#supportsFunctionCalling">
        <rdfs:label xml:lang="en">supports function calling</rdfs:label>
        <rdfs:comment xml:lang="tr">LLMModel'in fonksiyon cagrisi/tool-use ozelligini destekleyip desteklemedigini gosteren bool deger.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#LLMModel"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#taskName -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#taskName">
        <rdfs:label xml:lang="en">task name</rdfs:label>
        <rdfs:comment xml:lang="tr">Task ornegi icin insan-okur ad.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Task"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#taskPriority -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#taskPriority">
        <rdfs:label xml:lang="en">task priority</rdfs:label>
        <rdfs:comment xml:lang="tr">Task'in onceligi (integer).</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Task"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#taskStatus -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#taskStatus">
        <rdfs:label xml:lang="en">task status</rdfs:label>
        <rdfs:comment xml:lang="tr">Task durumu (pending, running, completed, failed).</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Task"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#templateName -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#templateName">
        <rdfs:label xml:lang="en">template name</rdfs:label>
        <rdfs:comment xml:lang="tr">AgentTemplate veya PromptTemplate ornegi icin insan-okur ad.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#AgentTemplate"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#templateVariables -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#templateVariables">
        <rdfs:label xml:lang="en">template variables</rdfs:label>
        <rdfs:comment xml:lang="tr">PromptTemplate'in bekledigi degiskenlerin listesi (JSON veya virgulle ayrilmis).</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#UserPrompt"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#templateVersion -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#templateVersion">
        <rdfs:label xml:lang="en">template version</rdfs:label>
        <rdfs:comment xml:lang="tr">AgentTemplate veya PromptTemplate'in surum etiketi.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#AgentTemplate"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#tokenCount -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#tokenCount">
        <rdfs:label xml:lang="en">token count</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Message veya Context icin token sayisi.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Observation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#toolEndpoint -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#toolEndpoint">
        <rdfs:label xml:lang="en">tool endpoint</rdfs:label>
        <rdfs:comment xml:lang="tr">Tool'un cagrilabilecegi endpoint (URI).</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Tool"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#toolName -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#toolName">
        <rdfs:label xml:lang="en">tool name</rdfs:label>
        <rdfs:comment xml:lang="tr">Tool ornegi icin insan-okur ad.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Tool"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#toolVersion -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#toolVersion">
        <rdfs:label xml:lang="en">tool version</rdfs:label>
        <rdfs:comment xml:lang="tr">Tool'un surum etiketi.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Tool"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#ttlSeconds -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#ttlSeconds">
        <rdfs:label xml:lang="en">ttl seconds</rdfs:label>
        <rdfs:comment xml:lang="tr">Memory icin saniye cinsinden yasam suresi (time-to-live).</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ShortTermMemory"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#updatedAt -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#updatedAt">
        <rdfs:label xml:lang="en">updated at</rdfs:label>
        <rdfs:comment xml:lang="tr">Son guncelleme zaman damgasi (xsd:dateTime).</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#vectorDimension -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#vectorDimension">
        <rdfs:label xml:lang="en">vector dimension</rdfs:label>
        <rdfs:comment xml:lang="tr">SemanticMemory icin gomme vektor boyutu (orn. 1536).</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#SemanticMemory"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#workflowName -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#workflowName">
        <rdfs:label xml:lang="en">workflow name</rdfs:label>
        <rdfs:comment xml:lang="tr">Workflow ornegi icin insan-okur ad.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Workflow"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#workflowStatus -->

    <owl:DatatypeProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#workflowStatus">
        <rdfs:label xml:lang="en">workflow status</rdfs:label>
        <rdfs:comment xml:lang="tr">Workflow durumu (running, completed, failed).</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Workflow"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#Action -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Action">
        <rdfs:label xml:lang="en">Action</rdfs:label>
        <rdfs:comment xml:lang="tr">Etmenin bir karar sonucunda gerceklestirdigi somut islem.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#Agent -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent">
        <rdfs:label xml:lang="en">Agent</rdfs:label>
        <rdfs:comment xml:lang="tr">Karar veren, yonlendiren ve diger bilesenleri orkestre eden temel varlik. BDM tabanli etmenler bu sinifin alt veya birey ornekleridir.</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://www.dmi.unict.it/oasis2#Agent"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#hasCapability"/>
                <owl:someValuesFrom rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Capability"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#hasConfiguration"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ModelConfiguration"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#AgentGroup -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#AgentGroup">
        <rdfs:label xml:lang="en">Agent Group</rdfs:label>
        <rdfs:comment xml:lang="tr">Ortak bir amac dogrultusunda birlikte calisan etmenlerin mantiksal organizasyonu (orn. arastirma takimi, kod inceleme takimi).</rdfs:comment>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#hasMember"/>
                <owl:allValuesFrom rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#AgentMessage -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#AgentMessage">
        <rdfs:label xml:lang="en">Agent Message</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir etmen tarafindan uretilmis Message alt tipi.</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Message"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#generatedBy"/>
                <owl:someValuesFrom rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#hasMessageRole"/>
                <owl:hasValue rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Assistant"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#UserMessage"/>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#AgentTemplate -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#AgentTemplate">
        <rdfs:label xml:lang="en">Agent Template</rdfs:label>
        <rdfs:comment xml:lang="tr">Somut bir etmen ornegi olusturmak icin kullanilan soyut yapilandirma sablonu; rol, model ve kabiliyet on-tanimlarini iceren prototip.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#Capability -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Capability">
        <rdfs:label xml:lang="en">Capability</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir etmenin sahip oldugu yetenek kumesinin soyut tanimi; oasis:Behaviour ile hizalanir.</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://www.dmi.unict.it/oasis2#Behaviour"/>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#Channel -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Channel">
        <rdfs:label xml:lang="en">Channel</rdfs:label>
        <rdfs:comment xml:lang="tr">Etmenler veya etmen ile kullanici arasindaki iletisim kanalinin soyut tanimi.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#CompressionStrategy -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#CompressionStrategy">
        <rdfs:label xml:lang="en">Compression Strategy</rdfs:label>
        <rdfs:comment xml:lang="tr">Baglam penceresinin token butcesine sigmasini saglayan ozetleme/sikistirma stratejisi (MemoryStrategy alt tipi).</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#MemoryStrategy"/>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#Context -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Context">
        <rdfs:label xml:lang="en">Context</rdfs:label>
        <rdfs:comment xml:lang="tr">Etmenin karar uretirken degerlendirdigi anlik baglam penceresi.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#Delegation -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Delegation">
        <rdfs:label xml:lang="en">Delegation</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir etmenin gorevi baska bir etmene devretme iliskisi.</rdfs:comment>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#delegatesTo"/>
                <owl:someValuesFrom rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#delegator"/>
                <owl:someValuesFrom rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#EpisodicMemory -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#EpisodicMemory">
        <rdfs:label xml:lang="en">Episodic Memory</rdfs:label>
        <rdfs:comment xml:lang="tr">Gecmis etkilesimlere ait olaysal (zaman/yer baglamli) kayitlari saklayan hafiza turu.</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Memory"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#recordsSession"/>
                <owl:allValuesFrom rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Session"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#EvictionStrategy -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#EvictionStrategy">
        <rdfs:label xml:lang="en">Eviction Strategy</rdfs:label>
        <rdfs:comment xml:lang="tr">Hafizadan oge cikarma (LRU, FIFO vb.) stratejisi (MemoryStrategy alt tipi).</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#MemoryStrategy"/>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#ExecutionContext -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#ExecutionContext">
        <rdfs:label xml:lang="en">Execution Context</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir gorevin calistirildigi ortam bilgisini ve durumunu kapsayan baglam nesnesi.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#LLMModel -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#LLMModel">
        <rdfs:label xml:lang="en">LLM Model</rdfs:label>
        <rdfs:comment xml:lang="tr">Etmenin cikti uretmek icin kullandigi buyuk dil modeli (orn. GPT-4o, Claude Sonnet).</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#LongTermMemory -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#LongTermMemory">
        <rdfs:label xml:lang="en">Long Term Memory</rdfs:label>
        <rdfs:comment xml:lang="tr">Oturumlar arasinda kalici olarak saklanan uzun vadeli bilgi deposu.</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Memory"/>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#Memory -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Memory">
        <rdfs:label xml:lang="en">Memory</rdfs:label>
        <rdfs:comment xml:lang="tr">Etmenin gecmis etkilesimlere ve bilgiye erisimini saglayan genel hafiza altyapisi (tum hafiza turlerinin ust sinifi).</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#MemoryStrategy -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#MemoryStrategy">
        <rdfs:label xml:lang="en">Memory Strategy</rdfs:label>
        <rdfs:comment xml:lang="tr">Hangi bilginin ne zaman saklanacagini, gomulecegini veya geri cagrilacagini belirleyen soyut strateji.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#Message -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Message">
        <rdfs:label xml:lang="en">Message</rdfs:label>
        <rdfs:comment xml:lang="tr">Kullanicidan ya da etmenden gelen, role ve siraya sahip tekil iletisim birimi.</rdfs:comment>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#hasMessageRole"/>
                <owl:allValuesFrom rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#MessageRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#MessageRole -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#MessageRole">
        <rdfs:label xml:lang="en">Message Role</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir mesajin sistemdeki rolunu belirleyen oneOf-tanimli sayilabilir tip (User, Assistant, System, ToolRole).</rdfs:comment>
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Assistant"/>
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#System"/>
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#ToolRole"/>
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#User"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#ModelConfiguration -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#ModelConfiguration">
        <rdfs:label xml:lang="en">Model Configuration</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir etmen icin kullanilacak LLM modeli ile parametrelerini (temperature, top_p, vb.) bir arada tanimlayan yapilandirma nesnesi.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#Observation -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Observation">
        <rdfs:label xml:lang="en">Observation</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir oturum sirasinda uretilen token kullanimi, gecikme ve hata gibi sistem duzeyindeki olcum kayitlari.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#Parameter -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Parameter">
        <rdfs:label xml:lang="en">Parameter</rdfs:label>
        <rdfs:comment xml:lang="tr">Modelin sicaklik ve maksimum token gibi calisma zamani ayarlarini tanimlayan deger.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#Plan -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Plan">
        <rdfs:label xml:lang="en">Plan</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir gorevi tamamlamak icin belirlenen sirali adimlar dizisi.</rdfs:comment>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#hasStep"/>
                <owl:allValuesFrom rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Task"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#Policy -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Policy">
        <rdfs:label xml:lang="en">Policy</rdfs:label>
        <rdfs:comment xml:lang="tr">Etmenin karar ve davranislarini kisitlayan veya yonlendiren kurallar butunu.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#Prompt -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Prompt">
        <rdfs:label xml:lang="en">Prompt</rdfs:label>
        <rdfs:comment xml:lang="tr">Modele gonderilen ve davranisi yonlendiren girdi metni (System ve User alt tipleri vardir).</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#Protocol -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Protocol">
        <rdfs:label xml:lang="en">Protocol</rdfs:label>
        <rdfs:comment xml:lang="tr">Etmenler arasi mesaj alisverisini duzenleyen iletisim kurallari butunu (orn. MCP, FIPA-ACL, JSON-RPC).</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#Resource -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Resource">
        <rdfs:label xml:lang="en">Resource</rdfs:label>
        <rdfs:comment xml:lang="tr">Etmenin erisebildigi dosya, veritabani veya harici servis gibi veri kaynaklari.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#RetrievalStrategy -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#RetrievalStrategy">
        <rdfs:label xml:lang="en">Retrieval Strategy</rdfs:label>
        <rdfs:comment xml:lang="tr">Hafizadan ilgili icerigi geri cagirma (vector-similarity, keyword vb.) stratejisi (MemoryStrategy alt tipi).</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#MemoryStrategy"/>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#Role -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Role">
        <rdfs:label xml:lang="en">Role</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir etmenin sistem icindeki islevsel konumunu ve sorumlulugunu belirleyen tanim (orn. Planner, Reviewer, Worker).</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#SemanticMemory -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#SemanticMemory">
        <rdfs:label xml:lang="en">Semantic Memory</rdfs:label>
        <rdfs:comment xml:lang="tr">Alan bilgisi ve olgusal bilgiyi (genellikle vektor temsiliyle) temsil eden yapilandirilmis bilgi tabani.</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Memory"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#hasMemoryStrategy"/>
                <owl:allValuesFrom rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#RetrievalStrategy"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#Session -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Session">
        <rdfs:label xml:lang="en">Session</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir kullanici ile etmen veya etmenler arasindaki belirli bir etkilesim surecini kapsayan baglam birimi.</rdfs:comment>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#hasMessage"/>
                <owl:someValuesFrom rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Message"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#sessionOf"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
                            <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#AgentGroup"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#ShortTermMemory -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#ShortTermMemory">
        <rdfs:label xml:lang="en">Short Term Memory</rdfs:label>
        <rdfs:comment xml:lang="tr">Aktif oturum suresince gecerli olan kisa vadeli baglam hafizasi.</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Memory"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#hasMemoryStrategy"/>
                <owl:allValuesFrom rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#EvictionStrategy"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#storesMessage"/>
                <owl:allValuesFrom rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Message"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#Subtask -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Subtask">
        <rdfs:label xml:lang="en">Subtask</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Task'in daha kucuk ve bagimsiz olarak yurutulebilir alt parcasi.</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Task"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#subtaskOf"/>
                <owl:someValuesFrom rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Task"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#SystemPrompt -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#SystemPrompt">
        <rdfs:label xml:lang="en">System Prompt</rdfs:label>
        <rdfs:comment xml:lang="tr">Etmenin genel davranisini, rolunu ve kisitlamalarini tanimlayan sabit yonerge.</rdfs:comment>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Prompt"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#forRole"/>
                        <owl:hasValue rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#System"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Prompt"/>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#Task -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Task">
        <rdfs:label xml:lang="en">Task</rdfs:label>
        <rdfs:comment xml:lang="tr">Etmenin tamamlamasi beklenen, tanimli giris ve cikisa sahip is birimi.</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://www.dmi.unict.it/oasis2#TaskDescription"/>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#Tool -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Tool">
        <rdfs:label xml:lang="en">Tool</rdfs:label>
        <rdfs:comment xml:lang="tr">Etmen tarafindan cagrilabilen, tanimli bir isi yerine getiren dissal fonksiyon veya sistem bileseni.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#ToolCall -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#ToolCall">
        <rdfs:label xml:lang="en">Tool Call</rdfs:label>
        <rdfs:comment xml:lang="tr">Etmenin bir araci belirli parametrelerle cagirma eylemi; argumanlari ve zaman damgasini kaydeder.</rdfs:comment>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#invokesTool"/>
                <owl:someValuesFrom rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Tool"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#ToolResult -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#ToolResult">
        <rdfs:label xml:lang="en">Tool Result</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir arac cagrisinin urettigi cikti ya da hata durumu.</rdfs:comment>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#resultOf"/>
                <owl:someValuesFrom rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ToolCall"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#UserMessage -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#UserMessage">
        <rdfs:label xml:lang="en">User Message</rdfs:label>
        <rdfs:comment xml:lang="tr">Kullanici (veya cagiran sistem) tarafindan uretilmis Message alt tipi.</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Message"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#hasMessageRole"/>
                <owl:hasValue rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#User"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#UserPrompt -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#UserPrompt">
        <rdfs:label xml:lang="en">User Prompt</rdfs:label>
        <rdfs:comment xml:lang="tr">Kullanici ya da cagiran sistem tarafindan saglanan, etmene yonlendirilen anlik talep veya soru.</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Prompt"/>
    </owl:Class>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#Workflow -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Workflow">
        <rdfs:label xml:lang="en">Workflow</rdfs:label>
        <rdfs:comment xml:lang="tr">Birden fazla etmen veya aracin koordineli bicimde yuruttugu surec akisi.</rdfs:comment>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#hasPlan"/>
                <owl:someValuesFrom rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Plan"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#Assistant -->

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Assistant">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#MessageRole"/>
    </owl:NamedIndividual>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#FIFO -->

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#FIFO">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#EvictionStrategy"/>
    </owl:NamedIndividual>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#FIPA_ACL -->

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#FIPA_ACL">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Protocol"/>
    </owl:NamedIndividual>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#JSON_RPC -->

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#JSON_RPC">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Protocol"/>
    </owl:NamedIndividual>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#LRU -->

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#LRU">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#EvictionStrategy"/>
    </owl:NamedIndividual>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#MCP -->

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#MCP">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Protocol"/>
    </owl:NamedIndividual>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#MaxTokensParam -->

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#MaxTokensParam">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Parameter"/>
        <paramName rdf:datatype="xsd:string">max_tokens</paramName>
        <paramType rdf:datatype="xsd:string">integer</paramType>
    </owl:NamedIndividual>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#Orchestrator -->

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Orchestrator">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Role"/>
    </owl:NamedIndividual>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#RAG -->

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#RAG">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#RetrievalStrategy"/>
    </owl:NamedIndividual>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#Reviewer -->

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Reviewer">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Role"/>
    </owl:NamedIndividual>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#Summarization -->

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Summarization">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#CompressionStrategy"/>
    </owl:NamedIndividual>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#System -->

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#System">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#MessageRole"/>
    </owl:NamedIndividual>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#TemperatureParam -->

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#TemperatureParam">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Parameter"/>
        <paramName rdf:datatype="xsd:string">temperature</paramName>
        <paramType rdf:datatype="xsd:string">float</paramType>
    </owl:NamedIndividual>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#ToolRole -->

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#ToolRole">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#MessageRole"/>
    </owl:NamedIndividual>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#TopPParam -->

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#TopPParam">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Parameter"/>
        <paramName rdf:datatype="xsd:string">top_p</paramName>
        <paramType rdf:datatype="xsd:string">float</paramType>
