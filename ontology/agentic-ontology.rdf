    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#User -->

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#User">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#MessageRole"/>
    </owl:NamedIndividual>
    


    <!-- http://www.ege.edu.tr/cs/ontology/llm-agent#Worker -->

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Worker">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Role"/>
    </owl:NamedIndividual>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // General axioms
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <rdf:Description>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AllDisjointClasses"/>
        <owl:members rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
            <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Memory"/>
            <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Message"/>
            <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Session"/>
            <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Tool"/>
        </owl:members>
    </rdf:Description>
    <rdf:Description>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AllDisjointClasses"/>
        <owl:members rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#CompressionStrategy"/>
            <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#EvictionStrategy"/>
            <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#RetrievalStrategy"/>
        </owl:members>
    </rdf:Description>
    <rdf:Description>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AllDisjointClasses"/>
        <owl:members rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#EpisodicMemory"/>
            <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#LongTermMemory"/>
            <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#SemanticMemory"/>
            <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#ShortTermMemory"/>
        </owl:members>
    </rdf:Description>
    <rdf:Description>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AllDifferent"/>
        <owl:distinctMembers rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Assistant"/>
            <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#System"/>
            <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#ToolRole"/>
            <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#User"/>
        </owl:distinctMembers>
    </rdf:Description>
    <rdf:Description>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AllDifferent"/>
        <owl:distinctMembers rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#MaxTokensParam"/>
            <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#TemperatureParam"/>
            <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#TopPParam"/>
        </owl:distinctMembers>
    </rdf:Description>


    <!-- ============================================================ -->
    <!-- FAZ 4: TANIMLI SINIFLAR (IntersectionOf, UnionOf, OneOf)    -->
    <!-- ============================================================ -->


    <!-- AutonomousAgent: Hafizasi olan ve aktif tool call yapan agent -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#AutonomousAgent">
        <rdfs:label xml:lang="en">Autonomous Agent</rdfs:label>
        <rdfs:comment xml:lang="tr">Hem hafizaya hem de arac cagirma yetenegine sahip etmenleri kapsayan equivalentClass tanimli sinif.</rdfs:comment>
        <rdfs:label>AutonomousAgent</rdfs:label>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#hasMemory"/>
                        <owl:someValuesFrom rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Memory"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#makesToolCall"/>
                        <owl:someValuesFrom rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ToolCall"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>


    <!-- MemoryAugmentedAgent: Uzun sureli hafizaya sahip agent -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#MemoryAugmentedAgent">
        <rdfs:label xml:lang="en">Memory Augmented Agent</rdfs:label>
        <rdfs:comment xml:lang="tr">Uzun vadeli hafizaya sahip etmenleri kapsayan equivalentClass tanimli sinif.</rdfs:comment>
        <rdfs:label>MemoryAugmentedAgent</rdfs:label>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#hasMemory"/>
                        <owl:someValuesFrom rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#LongTermMemory"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>


    <!-- PlanningAgent: Plan ureten ama tool call yapmayan agent -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#PlanningAgent">
        <rdfs:label xml:lang="en">Planning Agent</rdfs:label>
        <rdfs:comment xml:lang="tr">Plan ureten ancak dogrudan arac cagrisi yapmayan etmenleri kapsayan equivalentClass tanimli sinif.</rdfs:comment>
        <rdfs:label>PlanningAgent</rdfs:label>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#createsPlan"/>
                        <owl:someValuesFrom rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Plan"/>
                    </owl:Restriction>
                    <owl:Class>
                        <owl:complementOf>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#makesToolCall"/>
                                <owl:someValuesFrom rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#ToolCall"/>
                            </owl:Restriction>
                        </owl:complementOf>
                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>


    <!-- ExecutableEntity: Calistirilebilen varliklar (Task veya Workflow) -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#ExecutableEntity">
        <rdfs:label xml:lang="en">Executable Entity</rdfs:label>
        <rdfs:comment xml:lang="tr">Yurutulebilir varliklarin birlesik ust tipi (Task ile Workflow'un unionu).</rdfs:comment>
        <rdfs:label>ExecutableEntity</rdfs:label>
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Task"/>
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Workflow"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>


    <!-- MemoryContent: Hafizada saklanabilecek varliklar (Message veya Session) -->

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#MemoryContent">
        <rdfs:label xml:lang="en">Memory Content</rdfs:label>
        <rdfs:comment xml:lang="tr">Hafizada saklanabilir icerigin birlesik ust tipi (Message ile Session'in unionu); hafiza katmaninin ortak range'i olarak kullanilir.</rdfs:comment>
        <rdfs:label>MemoryContent</rdfs:label>
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Message"/>
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Session"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>


    <!-- ExecutionMode: Calistirma modu (kapali liste) -->

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Sync"/>
    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Async"/>

    <owl:Class rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#ExecutionMode">
        <rdfs:label xml:lang="en">Execution Mode</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Task'in calismasini niteleyen oneOf-tanimli sayilabilir tip (Sync, Async).</rdfs:comment>
        <rdfs:label>ExecutionMode</rdfs:label>
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Sync"/>
                    <rdf:Description rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#Async"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>



    <!-- ============================================================ -->
    <!-- FAZ 4: SOMUT BIREYLER - Cok-etmenli Arastirma Sistemi       -->
    <!-- ============================================================ -->

    <!-- Yeni Object Property: createsPlan (Agent -> Plan) -->
    <owl:ObjectProperty rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#createsPlan">
        <rdfs:label xml:lang="en">creates plan</rdfs:label>
        <rdfs:comment xml:lang="tr">Bir Agent'in urettigi Plan'i baglayan iliski; PlanningAgent tanimi icin kullanilir.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Agent"/>
        <rdfs:range rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#Plan"/>
    </owl:ObjectProperty>

    <!-- LLM MODELLER -->

    <owl:NamedIndividual rdf:about="http://www.ege.edu.tr/cs/ontology/llm-agent#GPT4o">
        <rdf:type rdf:resource="http://www.ege.edu.tr/cs/ontology/llm-agent#LLMModel"/>
