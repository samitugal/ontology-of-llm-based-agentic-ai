<?xml version="1.0"?>
<!--
  BDM Tabanli Etmen Sistemleri Ontolojisi
  Sami Tugal - Ege Universitesi Bilgisayar Muhendisligi
  ORCID: 0009-0008-6595-7053
  Faz 3 ornegi - 2026-04-28

  Format: OWL 2 XML Syntax (W3C OWL 2 XML Serialization)
  OASIS 2 entegrasyonu: oasis:Agent, oasis:TaskDescription, oasis:Behaviour
  Aksiyom kapsami: equivalentClass, someValuesFrom, allValuesFrom, hasValue, inverseOf
-->
<Ontology xmlns="http://www.w3.org/2002/07/owl#"
     xml:base="http://www.ege.edu.tr/cs/ontology/llm-agent"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:oasis="http://www.dmi.unict.it/oasis2#"
     ontologyIRI="http://www.ege.edu.tr/cs/ontology/llm-agent"
     versionIRI="http://www.ege.edu.tr/cs/ontology/llm-agent/0.1">

    <Prefix name="" IRI="http://www.ege.edu.tr/cs/ontology/llm-agent#"/>
    <Prefix name="owl" IRI="http://www.w3.org/2002/07/owl#"/>
    <Prefix name="rdf" IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#"/>
    <Prefix name="rdfs" IRI="http://www.w3.org/2000/01/rdf-schema#"/>
    <Prefix name="xsd" IRI="http://www.w3.org/2001/XMLSchema#"/>
    <Prefix name="oasis" IRI="http://www.dmi.unict.it/oasis2#"/>
    <Prefix name="dcterms" IRI="http://purl.org/dc/terms/"/>

    <Annotation>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <Literal>BDM Tabanli Etmen Sistemleri Ontolojisi. OASIS 2 ile entegre, cerceve bagimsiz LLM-agent ontolojisi.</Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty abbreviatedIRI="owl:versionInfo"/>
        <Literal>1.0.0</Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty abbreviatedIRI="dcterms:title"/>
        <Literal xml:lang="tr">BDM Tabanli Etmen Sistemleri Ontolojisi</Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty abbreviatedIRI="dcterms:creator"/>
        <Literal>Sami Tugal (ORCID: 0009-0008-6595-7053)</Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty abbreviatedIRI="dcterms:creator"/>
        <Literal>Murat Osman Unalir (ORCID: 0000-0003-4531-0566)</Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty abbreviatedIRI="dcterms:identifier"/>
        <Literal>https://doi.org/10.5281/zenodo.20571344</Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty abbreviatedIRI="dcterms:license"/>
        <Literal>https://creativecommons.org/licenses/by/4.0/</Literal>
    </Annotation>

    <!-- OASIS 2 ontolojisini import et (terminolojik referans) -->
    <Import>http://www.dmi.unict.it/oasis2</Import>

    <!-- ====================================================== -->
    <!-- KATMAN 1: CEKIRDEK VARLIKLAR                           -->
    <!-- ====================================================== -->
    <Declaration><Class IRI="#Agent"/></Declaration>
    <Declaration><Class IRI="#AgentGroup"/></Declaration>
    <Declaration><Class IRI="#AgentTemplate"/></Declaration>
    <Declaration><Class IRI="#Role"/></Declaration>
    <Declaration><Class IRI="#Policy"/></Declaration>

    <!-- KATMAN 2: ETKILESIM VE AKIS -->
    <Declaration><Class IRI="#Session"/></Declaration>
    <Declaration><Class IRI="#Message"/></Declaration>
    <Declaration><Class IRI="#UserMessage"/></Declaration>
    <Declaration><Class IRI="#AgentMessage"/></Declaration>
    <Declaration><Class IRI="#Observation"/></Declaration>
    <Declaration><Class IRI="#Context"/></Declaration>

    <!-- KATMAN 3: YETENEK -->
    <Declaration><Class IRI="#Tool"/></Declaration>
    <Declaration><Class IRI="#ToolCall"/></Declaration>
    <Declaration><Class IRI="#ToolResult"/></Declaration>
    <Declaration><Class IRI="#Resource"/></Declaration>
    <Declaration><Class IRI="#Action"/></Declaration>
    <Declaration><Class IRI="#Capability"/></Declaration>

    <!-- KATMAN 4: HAFIZA -->
    <Declaration><Class IRI="#Memory"/></Declaration>
    <Declaration><Class IRI="#ShortTermMemory"/></Declaration>
    <Declaration><Class IRI="#LongTermMemory"/></Declaration>
    <Declaration><Class IRI="#EpisodicMemory"/></Declaration>
    <Declaration><Class IRI="#SemanticMemory"/></Declaration>
    <Declaration><Class IRI="#MemoryStrategy"/></Declaration>
    <Declaration><Class IRI="#EvictionStrategy"/></Declaration>
    <Declaration><Class IRI="#RetrievalStrategy"/></Declaration>
    <Declaration><Class IRI="#CompressionStrategy"/></Declaration>

    <!-- KATMAN 5: MODEL VE YAPILANDIRMA -->
    <Declaration><Class IRI="#LLMModel"/></Declaration>
    <Declaration><Class IRI="#Prompt"/></Declaration>
    <Declaration><Class IRI="#SystemPrompt"/></Declaration>
    <Declaration><Class IRI="#UserPrompt"/></Declaration>
    <Declaration><Class IRI="#Parameter"/></Declaration>
    <Declaration><Class IRI="#ModelConfiguration"/></Declaration>

    <!-- KATMAN 6: ORKESTRASYON -->
    <Declaration><Class IRI="#Task"/></Declaration>
    <Declaration><Class IRI="#Subtask"/></Declaration>
    <Declaration><Class IRI="#Plan"/></Declaration>
    <Declaration><Class IRI="#Workflow"/></Declaration>
    <Declaration><Class IRI="#Delegation"/></Declaration>
    <Declaration><Class IRI="#ExecutionContext"/></Declaration>
    <Declaration><Class IRI="#Channel"/></Declaration>
    <Declaration><Class IRI="#Protocol"/></Declaration>
    <Declaration><Class IRI="#MessageRole"/></Declaration>

    <!-- ====================================================== -->
    <!-- OBJECT PROPERTY DECLARATIONS                           -->
    <!-- ====================================================== -->
    <Declaration><ObjectProperty IRI="#hasCapability"/></Declaration>
    <Declaration><ObjectProperty IRI="#capabilityOf"/></Declaration>
    <Declaration><ObjectProperty IRI="#hasMember"/></Declaration>
    <Declaration><ObjectProperty IRI="#memberOf"/></Declaration>
    <Declaration><ObjectProperty IRI="#hasMessage"/></Declaration>
    <Declaration><ObjectProperty IRI="#partOfSession"/></Declaration>
    <Declaration><ObjectProperty IRI="#invokesTool"/></Declaration>
    <Declaration><ObjectProperty IRI="#invokedBy"/></Declaration>
    <Declaration><ObjectProperty IRI="#producesResult"/></Declaration>
    <Declaration><ObjectProperty IRI="#resultOf"/></Declaration>
    <Declaration><ObjectProperty IRI="#delegatesTo"/></Declaration>
    <Declaration><ObjectProperty IRI="#delegatedBy"/></Declaration>
    <Declaration><ObjectProperty IRI="#hasMessageRole"/></Declaration>
    <Declaration><ObjectProperty IRI="#forRole"/></Declaration>
    <Declaration><ObjectProperty IRI="#hasStep"/></Declaration>
    <Declaration><ObjectProperty IRI="#hasMemory"/></Declaration>
    <Declaration><ObjectProperty IRI="#usesModel"/></Declaration>
    <Declaration><ObjectProperty IRI="#hasParameter"/></Declaration>
    <Declaration><ObjectProperty IRI="#hasMemoryStrategy"/></Declaration>
    <Declaration><ObjectProperty IRI="#followsProtocol"/></Declaration>
    <Declaration><ObjectProperty IRI="#hasConfiguration"/></Declaration>
    <!-- Yeni eklenenler (Faz 3 tamamlama) -->
    <Declaration><ObjectProperty IRI="#hasRole"/></Declaration>
    <Declaration><ObjectProperty IRI="#playedBy"/></Declaration>
    <Declaration><ObjectProperty IRI="#hasPolicy"/></Declaration>
    <Declaration><ObjectProperty IRI="#accessesResource"/></Declaration>
    <Declaration><ObjectProperty IRI="#hasObservation"/></Declaration>
    <Declaration><ObjectProperty IRI="#observedIn"/></Declaration>
    <Declaration><ObjectProperty IRI="#hasContext"/></Declaration>
    <Declaration><ObjectProperty IRI="#hasPlan"/></Declaration>
    <Declaration><ObjectProperty IRI="#viaChannel"/></Declaration>
    <Declaration><ObjectProperty IRI="#subtaskOf"/></Declaration>
    <Declaration><ObjectProperty IRI="#runsIn"/></Declaration>
    <Declaration><ObjectProperty IRI="#delegator"/></Declaration>
    <Declaration><ObjectProperty IRI="#delegatedTask"/></Declaration>
    <Declaration><ObjectProperty IRI="#hasAction"/></Declaration>
    <Declaration><ObjectProperty IRI="#instantiates"/></Declaration>
    <!-- Agent baglanti eksiklikleri -->
    <Declaration><ObjectProperty IRI="#hasSession"/></Declaration>
    <Declaration><ObjectProperty IRI="#sessionOf"/></Declaration>
    <Declaration><ObjectProperty IRI="#makesToolCall"/></Declaration>
    <Declaration><ObjectProperty IRI="#madeBy"/></Declaration>
    <!-- AgentConfiguration - Prompt baglantisi -->
    <Declaration><ObjectProperty IRI="#hasPrompt"/></Declaration>
    <Declaration><ObjectProperty IRI="#promptOf"/></Declaration>
    <!-- Capability - Tool baglantisi (CQ1) -->
    <Declaration><ObjectProperty IRI="#usesTool"/></Declaration>
    <Declaration><ObjectProperty IRI="#toolFor"/></Declaration>
    <!-- Delegation - Policy baglantisi (CQ4) -->
    <Declaration><ObjectProperty IRI="#triggeredBy"/></Declaration>
    <!-- AgentGroup - Workflow koordinasyon baglantisi (CQ6) -->
    <Declaration><ObjectProperty IRI="#coordinatesVia"/></Declaration>
    <!-- AgentMessage - Agent baglantisi (CQ5) -->
    <Declaration><ObjectProperty IRI="#generatedBy"/></Declaration>
    <!-- Memory icerik baglantilari -->
    <Declaration><ObjectProperty IRI="#storesMessage"/></Declaration>
    <Declaration><ObjectProperty IRI="#recordsSession"/></Declaration>
    <!-- AgentGroup paylasilan hafiza (CQ3-B) -->
    <Declaration><ObjectProperty IRI="#hasSharedMemory"/></Declaration>

    <!-- ====================================================== -->
    <!-- DATA PROPERTY DECLARATIONS - Sinif Attribute Tanimlari -->
    <!-- ====================================================== -->
    <!-- Genel/ortak attribute'lar -->
    <Declaration><DataProperty IRI="#hasDescription"/></Declaration>
    <Declaration><DataProperty IRI="#createdAt"/></Declaration>
    <Declaration><DataProperty IRI="#updatedAt"/></Declaration>

    <!-- Agent attribute'lari -->
    <Declaration><DataProperty IRI="#agentId"/></Declaration>
    <Declaration><DataProperty IRI="#agentName"/></Declaration>
    <Declaration><DataProperty IRI="#agentVersion"/></Declaration>
    <Declaration><DataProperty IRI="#isActive"/></Declaration>

    <!-- AgentGroup -->
    <Declaration><DataProperty IRI="#groupName"/></Declaration>

    <!-- AgentTemplate / AgentConfiguration -->
    <Declaration><DataProperty IRI="#templateName"/></Declaration>
    <Declaration><DataProperty IRI="#templateVersion"/></Declaration>

    <!-- Role / Policy -->
    <Declaration><DataProperty IRI="#roleName"/></Declaration>
    <Declaration><DataProperty IRI="#policyName"/></Declaration>
    <Declaration><DataProperty IRI="#policyExpression"/></Declaration>
    <Declaration><DataProperty IRI="#policyPriority"/></Declaration>

    <!-- Session / Message -->
    <Declaration><DataProperty IRI="#sessionId"/></Declaration>
    <Declaration><DataProperty IRI="#sessionStatus"/></Declaration>
    <Declaration><DataProperty IRI="#startTime"/></Declaration>
    <Declaration><DataProperty IRI="#endTime"/></Declaration>
    <Declaration><DataProperty IRI="#messageId"/></Declaration>
    <Declaration><DataProperty IRI="#messageContent"/></Declaration>
    <Declaration><DataProperty IRI="#messageTimestamp"/></Declaration>

    <!-- Observation -->
    <Declaration><DataProperty IRI="#tokenCount"/></Declaration>
    <Declaration><DataProperty IRI="#latencyMs"/></Declaration>
    <Declaration><DataProperty IRI="#errorCount"/></Declaration>
    <Declaration><DataProperty IRI="#cost"/></Declaration>
    <Declaration><DataProperty IRI="#observedAt"/></Declaration>

    <!-- Context -->
    <Declaration><DataProperty IRI="#contextWindowSize"/></Declaration>
    <Declaration><DataProperty IRI="#contextSnapshot"/></Declaration>

    <!-- Tool / ToolCall / ToolResult / Resource / Action / Capability -->
    <Declaration><DataProperty IRI="#toolName"/></Declaration>
    <Declaration><DataProperty IRI="#toolVersion"/></Declaration>
    <Declaration><DataProperty IRI="#toolEndpoint"/></Declaration>
    <Declaration><DataProperty IRI="#isAsync"/></Declaration>
    <Declaration><DataProperty IRI="#callId"/></Declaration>
    <Declaration><DataProperty IRI="#callTimestamp"/></Declaration>
    <Declaration><DataProperty IRI="#inputJson"/></Declaration>
    <Declaration><DataProperty IRI="#resultStatus"/></Declaration>
    <Declaration><DataProperty IRI="#resultPayload"/></Declaration>
    <Declaration><DataProperty IRI="#errorMessage"/></Declaration>
    <Declaration><DataProperty IRI="#executionTimeMs"/></Declaration>
    <Declaration><DataProperty IRI="#resourceURI"/></Declaration>
    <Declaration><DataProperty IRI="#resourceType"/></Declaration>
    <Declaration><DataProperty IRI="#accessMode"/></Declaration>
    <Declaration><DataProperty IRI="#actionName"/></Declaration>
    <Declaration><DataProperty IRI="#capabilityName"/></Declaration>

    <!-- Memory katmani -->
    <Declaration><DataProperty IRI="#memoryCapacity"/></Declaration>
    <Declaration><DataProperty IRI="#ttlSeconds"/></Declaration>
    <Declaration><DataProperty IRI="#persistenceBackend"/></Declaration>
    <Declaration><DataProperty IRI="#maxEpisodes"/></Declaration>
    <Declaration><DataProperty IRI="#vectorDimension"/></Declaration>
    <Declaration><DataProperty IRI="#embeddingModel"/></Declaration>
    <Declaration><DataProperty IRI="#strategyName"/></Declaration>
    <Declaration><DataProperty IRI="#strategyAlgorithm"/></Declaration>

    <!-- Model / Prompt / Parameter -->
    <Declaration><DataProperty IRI="#modelName"/></Declaration>
    <Declaration><DataProperty IRI="#modelProvider"/></Declaration>
    <Declaration><DataProperty IRI="#modelVersion"/></Declaration>
    <Declaration><DataProperty IRI="#contextLength"/></Declaration>
    <Declaration><DataProperty IRI="#supportsFunctionCalling"/></Declaration>
    <Declaration><DataProperty IRI="#promptText"/></Declaration>
    <Declaration><DataProperty IRI="#templateVariables"/></Declaration>
    <Declaration><DataProperty IRI="#paramName"/></Declaration>
    <Declaration><DataProperty IRI="#paramValue"/></Declaration>
    <Declaration><DataProperty IRI="#paramType"/></Declaration>

    <!-- Orkestrasyon: Task / Plan / Workflow / Delegation / Channel / Protocol -->
    <Declaration><DataProperty IRI="#taskName"/></Declaration>
    <Declaration><DataProperty IRI="#taskStatus"/></Declaration>
    <Declaration><DataProperty IRI="#taskPriority"/></Declaration>
    <Declaration><DataProperty IRI="#dueDate"/></Declaration>
    <Declaration><DataProperty IRI="#stepOrder"/></Declaration>
    <Declaration><DataProperty IRI="#planName"/></Declaration>
    <Declaration><DataProperty IRI="#planVersion"/></Declaration>
    <Declaration><DataProperty IRI="#workflowName"/></Declaration>
    <Declaration><DataProperty IRI="#workflowStatus"/></Declaration>
    <Declaration><DataProperty IRI="#delegatedAt"/></Declaration>
    <Declaration><DataProperty IRI="#delegationReason"/></Declaration>
    <Declaration><DataProperty IRI="#contextId"/></Declaration>
    <Declaration><DataProperty IRI="#environmentVars"/></Declaration>
    <Declaration><DataProperty IRI="#channelType"/></Declaration>
    <Declaration><DataProperty IRI="#channelEndpoint"/></Declaration>
    <Declaration><DataProperty IRI="#protocolName"/></Declaration>
    <Declaration><DataProperty IRI="#protocolVersion"/></Declaration>

    <!-- NAMED INDIVIDUALS -->
    <Declaration><NamedIndividual IRI="#User"/></Declaration>
    <Declaration><NamedIndividual IRI="#Assistant"/></Declaration>
    <Declaration><NamedIndividual IRI="#System"/></Declaration>
    <Declaration><NamedIndividual IRI="#ToolRole"/></Declaration>
    <Declaration><NamedIndividual IRI="#Orchestrator"/></Declaration>
    <Declaration><NamedIndividual IRI="#Worker"/></Declaration>
    <Declaration><NamedIndividual IRI="#Reviewer"/></Declaration>
    <Declaration><NamedIndividual IRI="#TemperatureParam"/></Declaration>
    <Declaration><NamedIndividual IRI="#MaxTokensParam"/></Declaration>
    <Declaration><NamedIndividual IRI="#TopPParam"/></Declaration>
    <Declaration><NamedIndividual IRI="#FIFO"/></Declaration>
    <Declaration><NamedIndividual IRI="#LRU"/></Declaration>
    <Declaration><NamedIndividual IRI="#RAG"/></Declaration>
    <Declaration><NamedIndividual IRI="#Summarization"/></Declaration>
    <Declaration><NamedIndividual IRI="#FIPA_ACL"/></Declaration>
    <Declaration><NamedIndividual IRI="#MCP"/></Declaration>
    <Declaration><NamedIndividual IRI="#JSON_RPC"/></Declaration>

    <!-- ====================================================== -->
    <!-- TAKSONOMI: SUBCLASS HIYERARSISI                        -->
    <!-- ====================================================== -->
    <SubClassOf>
        <Class IRI="#ShortTermMemory"/>
        <Class IRI="#Memory"/>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#LongTermMemory"/>
        <Class IRI="#Memory"/>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#EpisodicMemory"/>
        <Class IRI="#Memory"/>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#SemanticMemory"/>
        <Class IRI="#Memory"/>
    </SubClassOf>

    <!-- MemoryStrategy alt sinif hiyerarsisi -->
    <SubClassOf>
        <Class IRI="#EvictionStrategy"/>
        <Class IRI="#MemoryStrategy"/>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#RetrievalStrategy"/>
        <Class IRI="#MemoryStrategy"/>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#CompressionStrategy"/>
        <Class IRI="#MemoryStrategy"/>
    </SubClassOf>

    <!-- ShortTermMemory yalnizca EvictionStrategy kullanabilir -->
    <SubClassOf>
        <Class IRI="#ShortTermMemory"/>
        <ObjectAllValuesFrom>
            <ObjectProperty IRI="#hasMemoryStrategy"/>
            <Class IRI="#EvictionStrategy"/>
        </ObjectAllValuesFrom>
    </SubClassOf>

    <!-- SemanticMemory yalnizca RetrievalStrategy kullanabilir -->
    <SubClassOf>
        <Class IRI="#SemanticMemory"/>
        <ObjectAllValuesFrom>
            <ObjectProperty IRI="#hasMemoryStrategy"/>
            <Class IRI="#RetrievalStrategy"/>
        </ObjectAllValuesFrom>
    </SubClassOf>

    <!-- ShortTermMemory icerigi: son mesajlar -->
    <SubClassOf>
        <Class IRI="#ShortTermMemory"/>
        <ObjectAllValuesFrom>
            <ObjectProperty IRI="#storesMessage"/>
            <Class IRI="#Message"/>
        </ObjectAllValuesFrom>
    </SubClassOf>

    <!-- EpisodicMemory icerigi: gecmis sessionlar -->
    <SubClassOf>
        <Class IRI="#EpisodicMemory"/>
        <ObjectAllValuesFrom>
            <ObjectProperty IRI="#recordsSession"/>
            <Class IRI="#Session"/>
        </ObjectAllValuesFrom>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#UserMessage"/>
        <Class IRI="#Message"/>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#UserMessage"/>
        <ObjectHasValue>
            <ObjectProperty IRI="#hasMessageRole"/>
            <NamedIndividual IRI="#User"/>
        </ObjectHasValue>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#AgentMessage"/>
        <Class IRI="#Message"/>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#AgentMessage"/>
        <ObjectHasValue>
            <ObjectProperty IRI="#hasMessageRole"/>
            <NamedIndividual IRI="#Assistant"/>
        </ObjectHasValue>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#AgentMessage"/>
        <ObjectSomeValuesFrom>
            <ObjectProperty IRI="#generatedBy"/>
            <Class IRI="#Agent"/>
        </ObjectSomeValuesFrom>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#SystemPrompt"/>
        <Class IRI="#Prompt"/>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#UserPrompt"/>
        <Class IRI="#Prompt"/>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#Subtask"/>
        <Class IRI="#Task"/>
    </SubClassOf>

    <!-- ====================================================== -->
    <!-- (1) SUBCLASSOF - OASIS 2 ENTEGRASYONU                   -->
    <!-- my:Agent, oasis:Agent'in daha ozellesmiş versiyonudur. -->
    <!-- Terminolojik referans: hasBehaviour mirasi alinir,     -->
    <!-- ancak extension'lar esitlenmez.                        -->
    <!-- ====================================================== -->
    <SubClassOf>
        <Class IRI="#Agent"/>
        <Class abbreviatedIRI="oasis:Agent"/>
    </SubClassOf>

    <!-- (1.b) my:Task ⊑ oasis:TaskDescription                  -->
    <!-- OASIS 2 atomik gorev tanimi terminolojik referans.     -->
    <SubClassOf>
        <Class IRI="#Task"/>
        <Class abbreviatedIRI="oasis:TaskDescription"/>
    </SubClassOf>

    <!-- my:Capability rdfs:subClassOf oasis:Behaviour          -->
    <!-- Kavramsal hierarsi: Yetenek soyutlamasi, OASIS 2'deki  -->
    <!-- Behaviour davranis sinifinin alt sinifidir.            -->
    <SubClassOf>
        <Class IRI="#Capability"/>
        <Class abbreviatedIRI="oasis:Behaviour"/>
    </SubClassOf>

    <!-- ====================================================== -->
    <!-- (2) EQUIVALENT CLASS - ENUMERATED (oneOf)              -->
    <!-- MessageRole tam 4 bireyden olusan kapali bir sinif.    -->
    <!-- ====================================================== -->
    <EquivalentClasses>
        <Class IRI="#MessageRole"/>
        <ObjectOneOf>
            <NamedIndividual IRI="#User"/>
            <NamedIndividual IRI="#Assistant"/>
            <NamedIndividual IRI="#System"/>
            <NamedIndividual IRI="#ToolRole"/>
        </ObjectOneOf>
    </EquivalentClasses>

    <!-- ====================================================== -->
    <!-- (3) hasValue + equivalentClass - SystemPrompt          -->
    <!-- SystemPrompt, "forRole" degeri 'System' olan Prompt'tur-->
    <!-- ====================================================== -->
    <EquivalentClasses>
        <Class IRI="#SystemPrompt"/>
        <ObjectIntersectionOf>
            <Class IRI="#Prompt"/>
            <ObjectHasValue>
                <ObjectProperty IRI="#forRole"/>
                <NamedIndividual IRI="#System"/>
            </ObjectHasValue>
        </ObjectIntersectionOf>
    </EquivalentClasses>

    <!-- ====================================================== -->
    <!-- (4) someValuesFrom KISITLARI                           -->
    <!-- ====================================================== -->
    <!-- Her Agent en az bir Capability sahibidir. -->
    <SubClassOf>
        <Class IRI="#Agent"/>
        <ObjectSomeValuesFrom>
            <ObjectProperty IRI="#hasCapability"/>
            <Class IRI="#Capability"/>
        </ObjectSomeValuesFrom>
    </SubClassOf>

    <!-- Her Session en az bir Message icermelidir. -->
    <SubClassOf>
        <Class IRI="#Session"/>
        <ObjectSomeValuesFrom>
            <ObjectProperty IRI="#hasMessage"/>
            <Class IRI="#Message"/>
        </ObjectSomeValuesFrom>
    </SubClassOf>

    <!-- Her Session mutlaka bir Agent veya AgentGroup'a ait olmalidir. -->
    <SubClassOf>
        <Class IRI="#Session"/>
        <ObjectSomeValuesFrom>
            <ObjectProperty IRI="#sessionOf"/>
            <ObjectUnionOf>
                <Class IRI="#Agent"/>
                <Class IRI="#AgentGroup"/>
            </ObjectUnionOf>
        </ObjectSomeValuesFrom>
    </SubClassOf>

    <!-- Her ToolCall mutlaka bir Tool cagirir. -->
    <SubClassOf>
        <Class IRI="#ToolCall"/>
        <ObjectSomeValuesFrom>
            <ObjectProperty IRI="#invokesTool"/>
            <Class IRI="#Tool"/>
        </ObjectSomeValuesFrom>
    </SubClassOf>

    <!-- Her Delegation en az bir Agent'a (delegatee) yonelir. -->
    <SubClassOf>
        <Class IRI="#Delegation"/>
        <ObjectSomeValuesFrom>
            <ObjectProperty IRI="#delegatesTo"/>
            <Class IRI="#Agent"/>
        </ObjectSomeValuesFrom>
    </SubClassOf>

    <!-- Her ToolResult mutlaka bir ToolCall'dan uretilmis olmalidir. -->
    <SubClassOf>
        <Class IRI="#ToolResult"/>
        <ObjectSomeValuesFrom>
            <ObjectProperty IRI="#resultOf"/>
            <Class IRI="#ToolCall"/>
        </ObjectSomeValuesFrom>
    </SubClassOf>

    <!-- Her Subtask mutlaka bir ust Task'a bagli olmalidir. -->
    <SubClassOf>
        <Class IRI="#Subtask"/>
        <ObjectSomeValuesFrom>
            <ObjectProperty IRI="#subtaskOf"/>
            <Class IRI="#Task"/>
        </ObjectSomeValuesFrom>
    </SubClassOf>

    <!-- Her Delegation'in mutlaka bir gonderen Agent'i olmalidir. -->
    <SubClassOf>
        <Class IRI="#Delegation"/>
        <ObjectSomeValuesFrom>
            <ObjectProperty IRI="#delegator"/>
            <Class IRI="#Agent"/>
        </ObjectSomeValuesFrom>
    </SubClassOf>

    <!-- Her Workflow en az bir Plan icermek zorundadir. -->
    <SubClassOf>
        <Class IRI="#Workflow"/>
        <ObjectSomeValuesFrom>
            <ObjectProperty IRI="#hasPlan"/>
            <Class IRI="#Plan"/>
        </ObjectSomeValuesFrom>
    </SubClassOf>

    <!-- ====================================================== -->
    <!-- (5) allValuesFrom KISITLARI                            -->
    <!-- ====================================================== -->
    <!-- AgentGroup yalnizca Agent uyelerine sahip olabilir. -->
    <SubClassOf>
        <Class IRI="#AgentGroup"/>
        <ObjectAllValuesFrom>
            <ObjectProperty IRI="#hasMember"/>
            <Class IRI="#Agent"/>
        </ObjectAllValuesFrom>
    </SubClassOf>

    <!-- Plan yalnizca Task tipi adimlardan olusabilir. -->
    <SubClassOf>
        <Class IRI="#Plan"/>
        <ObjectAllValuesFrom>
            <ObjectProperty IRI="#hasStep"/>
            <Class IRI="#Task"/>
        </ObjectAllValuesFrom>
    </SubClassOf>

    <!-- Message yalnizca MessageRole tipinde role'e sahip olabilir. -->
    <SubClassOf>
        <Class IRI="#Message"/>
        <ObjectAllValuesFrom>
            <ObjectProperty IRI="#hasMessageRole"/>
            <Class IRI="#MessageRole"/>
        </ObjectAllValuesFrom>
    </SubClassOf>

    <!-- ====================================================== -->
    <!-- (6) INVERSE OBJECT PROPERTIES                          -->
    <!-- ====================================================== -->
    <InverseObjectProperties>
        <ObjectProperty IRI="#hasCapability"/>
        <ObjectProperty IRI="#capabilityOf"/>
    </InverseObjectProperties>
    <InverseObjectProperties>
        <ObjectProperty IRI="#hasMember"/>
        <ObjectProperty IRI="#memberOf"/>
    </InverseObjectProperties>
    <InverseObjectProperties>
        <ObjectProperty IRI="#hasMessage"/>
        <ObjectProperty IRI="#partOfSession"/>
    </InverseObjectProperties>
    <InverseObjectProperties>
        <ObjectProperty IRI="#invokesTool"/>
        <ObjectProperty IRI="#invokedBy"/>
    </InverseObjectProperties>
    <InverseObjectProperties>
        <ObjectProperty IRI="#producesResult"/>
        <ObjectProperty IRI="#resultOf"/>
    </InverseObjectProperties>
    <InverseObjectProperties>
        <ObjectProperty IRI="#delegatesTo"/>
        <ObjectProperty IRI="#delegatedBy"/>
    </InverseObjectProperties>

    <!-- ====================================================== -->
    <!-- DOMAIN / RANGE TANIMLARI                                -->
    <!-- ====================================================== -->
    <ObjectPropertyDomain>
        <ObjectProperty IRI="#hasCapability"/>
        <Class IRI="#Agent"/>
    </ObjectPropertyDomain>
    <ObjectPropertyRange>
        <ObjectProperty IRI="#hasCapability"/>
        <Class IRI="#Capability"/>
    </ObjectPropertyRange>

    <ObjectPropertyDomain>
        <ObjectProperty IRI="#hasMember"/>
        <Class IRI="#AgentGroup"/>
    </ObjectPropertyDomain>
    <ObjectPropertyRange>
        <ObjectProperty IRI="#hasMember"/>
        <Class IRI="#Agent"/>
    </ObjectPropertyRange>

    <ObjectPropertyDomain>
        <ObjectProperty IRI="#hasMessage"/>
        <Class IRI="#Session"/>
    </ObjectPropertyDomain>
