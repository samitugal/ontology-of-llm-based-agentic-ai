    <IrreflexiveObjectProperty><ObjectProperty IRI="#subtaskOf"/></IrreflexiveObjectProperty>
    <AsymmetricObjectProperty><ObjectProperty IRI="#delegatesTo"/></AsymmetricObjectProperty>
