    <InverseFunctionalObjectProperty><ObjectProperty IRI="#hasConfiguration"/></InverseFunctionalObjectProperty>

    <!-- Asymmetric / Irreflexive: bir Task kendisinin alt gorevi olamaz, etmen kendine delegasyon yapamaz -->
